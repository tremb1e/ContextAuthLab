    <!-- Privacy Agreement Dialog -->
    <string name="privacy_welcome">Welcome to ContextAuthLab. This app is designed for academic research on redacted Android context and motion-sensor data. Please read and accept the privacy policy to continue.</string>
    <string name="privacy_data_collection_title">Data Collection:</string>
    <string name="privacy_data_collection_content">We collect the following data for research purposes:\n• Motion sensors: accelerometer, gyroscope, and magnetic field at 100Hz\n• Redacted Accessibility component structure and context features\n• Research device ID derived from ANDROID_ID with the server study salt\n• Collection occurs only when consent, permissions, server health, ClockSync, screen/unlock state, and the Wi-Fi policy are ready</string>
    <string name="privacy_data_usage_title">Data Usage:</string>
    <string name="privacy_data_usage_content">All collected data is used exclusively for:\n• Academic research on Android context and motion patterns\n• Data-quality analysis for later continuous-authentication research\n• Statistical analysis of task categories and sensor/context alignment\n• No commercial use or sale of data</string>
    <string name="privacy_data_storage_title">Data Storage &amp; Transport:</string>
    <string name="privacy_data_storage_content">• Redaction first: raw input text is dropped and sensitive fixed-format text is replaced before upload\n• Compression: each batch is JSON serialized and compressed with LZ4 frame\n• Integrity: each envelope includes SHA-256 of the compressed bytes\n• Confidentiality: deployment relies on HTTPS/TLS; this prototype does not use content AES encryption</string>
    <string name="privacy_data_sharing_title">Data Transmission &amp; Sharing:</string>
    <string name="privacy_data_sharing_content">• Secure transmission: deployment should use HTTPS/TLS 1.2 or newer\n• No third-party sharing: raw payloads are not shared with third parties\n• Research use only: data is transmitted only to configured research servers\n• Local HTTP is intended only for emulator or lab testing</string>
    <string name="privacy_user_rights_title">Your Rights &amp; Controls:</string>
    <string name="privacy_user_rights_content">You have complete control over your data:\n• Withdraw consent: Stop data collection at any time\n• Data deletion: Request complete deletion from both device and servers\n• Data export: Request a copy of your collected data\n• Retention limit: Data is automatically deleted after the configured retention period (default: 30 days)\n• Transparency: View collection status and statistics at any time</string>
    <string name="privacy_contact_title">Contact &amp; Support:</string>
    <string name="privacy_contact_content">For privacy concerns, data requests, or questions:\n• Email: privacy@continuousauth.research\n• Response time: Within 48 hours\n• Data deletion requests processed within 7 days</string>
    
