<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- 
        Exclude sensitive data from cloud backups
        -->
        <exclude domain="sharedpref" path="contextauthlab_secure.xml"/>
        <exclude domain="sharedpref" path="contextauthlab_secure_fallback.xml"/>
        <exclude domain="sharedpref" path="contextauthlab_settings.xml"/>
        <exclude domain="database" path="upload_queue.db"/>
        <exclude domain="file" path="upload_queue/"/>
        <exclude domain="file" path="dead_letter/"/>
    </cloud-backup>
    
    <device-transfer>
        <!-- 
        Exclude sensitive data from device transfers
        -->
        <exclude domain="sharedpref" path="contextauthlab_secure.xml"/>
        <exclude domain="sharedpref" path="contextauthlab_secure_fallback.xml"/>
        <exclude domain="sharedpref" path="contextauthlab_settings.xml"/>
        <exclude domain="database" path="upload_queue.db"/>
        <exclude domain="file" path="upload_queue/"/>
        <exclude domain="file" path="dead_letter/"/>
    </device-transfer>
</data-extraction-rules>
