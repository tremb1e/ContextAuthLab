# Server
SERVER_BIND=127.0.0.1
SERVER_PORT=8000
SERVER_STUDY_SALT=Continuous_Authentication
RULES_VERSION=1
# Optional; defaults to ${SERVER_DATA_DIR}/rules.json inside the container.
# SERVER_RULES_FILE=/data/paper/rules.json
SERVER_FIX_PERMISSIONS=true
SERVER_CHOWN_RECURSIVE=true
INGEST_REQUIRE_AUTH=false
TZ=Asia/Shanghai
VERSION=latest

# Production volume override
# DATA_VOLUME=/var/lib/contextauthlab/data/paper
# LOG_VOLUME=/var/log/contextauthlab
# Numeric uid/gid used by the non-root API process and mounted data files.
SERVER_CONTAINER_UID=1000
SERVER_CONTAINER_GID=1000
